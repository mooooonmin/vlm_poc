# 앱 서버 설정
APP_HOST=127.0.0.1
APP_PORT=8080

# 기본 VLM 모델과 vLLM endpoint
MODEL_ID=Qwen/Qwen3-VL-2B-Instruct
VLLM_ENDPOINT=http://localhost:8000/v1/chat/completions
VLLM_MODELS_ENDPOINT=http://localhost:8000/v1/models

# Docker vLLM 컨테이너 설정
CONTAINER_NAME=vlm-vllm-qwen
VLLM_IMAGE=vllm/vllm-openai:latest
GPU_MEMORY_UTILIZATION=0.85
MAX_MODEL_LEN=8192

# Hugging Face 설정
# 공개 모델만 사용할 때는 비워둘 수 있습니다.
HF_TOKEN=
HF_HOME=

# 영상 입력 제한
MAX_UPLOAD_BYTES=1073741824
MAX_VIDEO_DURATION_SEC=1800

# 한국어 응답 보정
KOREAN_RETRY_ENABLED=1
KOREAN_MIN_HANGUL=5
KOREAN_MIN_RATIO=0.2

# 다중 vLLM worker 설정
# 미설정이면 VLLM_ENDPOINT 1개만 사용합니다.
# 예: VLLM_WORKERS=http://localhost:8000/v1/chat/completions,http://localhost:8001/v1/chat/completions
VLLM_WORKERS=
